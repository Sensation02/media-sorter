# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — safe place for secrets.
#
# Loading: Claude Code reads env vars from the shell at startup.
# Either export the var in your shell rc, or run:
#   set -a && source .env.local && set +a && claude

# Notion integration token for the Notion MCP server.
# Create an integration: https://www.notion.so/profile/integrations
# Then share the relevant pages/databases with that integration via
# `...` -> Connections on each page. The integration sees nothing otherwise.
NOTION_API_KEY=secret_replace_me
